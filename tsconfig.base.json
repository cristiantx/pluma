{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "newLine": "lf",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@pluma/core": ["packages/core/src/index.ts"],
      "@pluma/core-desktop": ["packages/core/src/desktop.ts"],
      "@pluma/editor": ["packages/editor/src/index.ts"],
      "@pluma/ui": ["packages/ui/src/index.ts"]
    }
  }
}
