{
  "globs": ["docs/**/*.md", "*.md"],
  "ignores": ["node_modules/**"],
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false,
    "MD034": false,
    "MD041": false,
    "MD004": {
      "style": "dash"
    },
    "MD007": {
      "indent": 2
    },
    "MD046": {
      "style": "fenced"
    }
  }
}
